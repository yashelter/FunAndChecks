<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@StudentName@(string.IsNullOrEmpty(GroupName) ? "" : $" ({GroupName})")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="2" Rounded="true" Centered="true">
            <MudTabPanel Text="Задачи">
                @if (_loadingTasks)
                {
                    <div class="d-flex justify-center pa-4"><MudProgressCircular Indeterminate="true" /></div>
                }
                else
                {
                    <MudList T="TaskWithStatusDto" ReadOnly="true">
                        @foreach (var task in _tasks)
                        {
                            <MudPaper Outlined="true" Class="pa-3 mb-3">
                                <div class="d-flex justify-space-between align-start">
                                    <div>
                                        <MudText Typo="Typo.body1"><b>@task.Name</b> (@task.MaxPoints б.)</MudText>
                                        <MudChip T="string" Label="true" Size="Size.Small" Color="@StatusColor(task.Status)">
                                            @StatusText(task.Status)
                                        </MudChip>
                                    </div>
                                    <MudStack Spacing="1" AlignItems="AlignItems.End">
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                                   OnClick="@(() => SubmitAsync(task.Id, SubmissionStatus.Accepted))">Зачтено</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                                   OnClick="@(() => ReworkAsync(task.Id))">На доработку</MudButton>
                                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                                   OnClick="@(() => ToggleHistoryAsync(task.Id))">
                                            @(_openHistory.Contains(task.Id) ? "Скрыть историю" : "История")
                                        </MudButton>
                                    </MudStack>
                                </div>

                                @if (_openHistory.Contains(task.Id))
                                {
                                    <MudDivider Class="my-2" />
                                    @if (!_history.TryGetValue(task.Id, out var log))
                                    {
                                        <MudProgressLinear Indeterminate="true" />
                                    }
                                    else if (log.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption">Сдач ещё не было.</MudText>
                                    }
                                    else
                                    {
                                        @foreach (var entry in log)
                                        {
                                            <div class="mb-1">
                                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(entry.Status)">@StatusText(entry.Status)</MudChip>
                                                <MudText Typo="Typo.caption" Class="d-inline">
                                                    @entry.Admin.FullName · @entry.SubmittedAt.ToLocalTime().ToString("dd.MM HH:mm")
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(entry.Comment))
                                                {
                                                    <MudText Typo="Typo.body2">Причина: @entry.Comment</MudText>
                                                }
                                            </div>
                                        }
                                    }
                                }
                            </MudPaper>
                        }
                    </MudList>
                }
            </MudTabPanel>

            <MudTabPanel Text="Оценки">
                @if (_components.Count == 0)
                {
                    <MudText Class="pa-4">У предмета нет оценочных колонок (билет, курсовая).</MudText>
                }
                else
                {
                    <MudList T="GradeComponentDto" ReadOnly="true">
                        @foreach (var c in _components)
                        {
                            <MudPaper Outlined="true" Class="pa-3 mb-2">
                                <div class="d-flex justify-space-between align-center gap-2">
                                    <div>
                                        <MudText><b>@c.Name</b> (@c.MinPoints–@c.MaxPoints)</MudText>
                                        @if (_currentGrades.TryGetValue(c.Id, out var current))
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Сейчас: @current</MudChip>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption">Не выставлено</MudText>
                                        }
                                    </div>
                                    <div class="d-flex align-center gap-2">
                                        <MudNumericField T="int" @bind-Value="_gradeInputs[c.Id]"
                                                         Min="@c.MinPoints" Max="@c.MaxPoints"
                                                         Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 100px;" />
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   OnClick="@(() => SetGradeAsync(c.Id))">ОК</MudButton>
                                    </div>
                                </div>
                            </MudPaper>
                        }
                    </MudList>
                }
            </MudTabPanel>

            <MudTabPanel Text="Цвет">
                <MudStack Spacing="3" Class="pa-2">
                    <MudText Typo="Typo.body2">Заливка ячейки ФИО студента в таблице результатов.</MudText>
                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Outlined" OnClick="@(() => ApplyColorAsync(null))">Убрать заливку</MudButton>
                        <MudButton Variant="Variant.Filled" Style="background-color:#43A047;color:#fff;"
                                   OnClick="@(() => ApplyColorAsync(GreenColor))">Зелёный</MudButton>
                        <MudButton Variant="Variant.Filled" Style="background-color:#8D6E63;color:#fff;"
                                   OnClick="@(() => ApplyColorAsync(BrownColor))">Коричневый</MudButton>
                    </MudStack>

                    <MudColorPicker @bind-Text="_pickerColor" Label="Свой цвет" PickerVariant="PickerVariant.Static"
                                    ColorPickerMode="ColorPickerMode.HEX" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@string.IsNullOrEmpty(_pickerColor)"
                               OnClick="@(() => ApplyColorAsync(_pickerColor))">Применить выбранный</MudButton>
                </MudStack>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <div class="d-flex flex-wrap gap-2 pa-2" style="width:100%;">
            @if (EventId is not null)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           OnClick="@(() => ChangeStatusAsync(QueueEntryStatus.Finished))">Завершил</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Warning"
                           OnClick="@(() => ChangeStatusAsync(QueueEntryStatus.Skipped))">Пропущен</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info"
                           OnClick="@(() => ChangeStatusAsync(QueueEntryStatus.Waiting))">В очередь</MudButton>
            }
            <MudSpacer />
            <MudButton OnClick="Cancel">@(EventId is null ? "Закрыть" : "Свернуть")</MudButton>
        </div>
    </DialogActions>
</MudDialog>
