<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Комментарий к доработке</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_comment" Label="Причина доработки" Variant="Variant.Outlined" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Отправить</MudButton>
    </DialogActions>
</MudDialog>
