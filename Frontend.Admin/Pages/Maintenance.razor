@page "/admin/maintenance"
@layout AdminLayout
@attribute [Authorize(Roles = Roles.SuperAdmin)]

<PageTitle>Обслуживание</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Обслуживание</MudText>
<MudText Typo="Typo.body2" GutterBottom="true">
    Управление сущностями (создание, изменение, удаление) — на странице «Управление».
</MudText>

<MudCard Elevation="4" Class="mt-4" Style="max-width: 640px;">
    <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Резервная копия БД</MudText></CardHeaderContent></MudCardHeader>
    <MudCardContent>
        <MudText Typo="Typo.body2">Создаёт дамп БД на сервере (pg_dump) в настроенный каталог.</MudText>
        @if (_lastBackupPath is not null)
        {
            <MudAlert Severity="Severity.Success" Class="mt-2">Создан: @_lastBackupPath</MudAlert>
        }
    </MudCardContent>
    <MudCardActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Backup"
                   OnClick="BackupAsync" Disabled="_backupRunning">
            @if (_backupRunning) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Создать бэкап
        </MudButton>
    </MudCardActions>
</MudCard>
