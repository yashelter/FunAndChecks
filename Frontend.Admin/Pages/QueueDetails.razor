@page "/admin/queues/{EventId:int}"
@layout AdminLayout
@attribute [Authorize(Roles = Roles.Admin)]
@implements IAsyncDisposable

<PageTitle>Очередь</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-center align-center" style="height: 50vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </div>
}
else if (_details is not null)
{
    <div class="d-flex align-center mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="/admin/queues" Edge="Edge.Start" />
        <MudText Typo="Typo.h4" Class="ml-2">@_details.EventName</MudText>
    </div>
    <MudText Typo="Typo.subtitle1" GutterBottom="true">Предмет: @_details.SubjectName</MudText>

    <div class="d-flex flex-wrap gap-3 align-center mt-2">
        <MudTextField @bind-Value="_filter" Label="Фильтр (ФИО/группа)" Variant="Variant.Outlined"
                      Margin="Margin.Dense" Clearable="true" Style="max-width: 280px;"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        <MudSelect T="ParticipantSort" @bind-Value="_sort" Label="Сортировка (внутри статуса)" Variant="Variant.Outlined"
                   Margin="Margin.Dense" Style="max-width: 240px;">
            <MudSelectItem T="ParticipantSort" Value="ParticipantSort.Points">По баллам</MudSelectItem>
            <MudSelectItem T="ParticipantSort" Value="ParticipantSort.Group">По группе</MudSelectItem>
            <MudSelectItem T="ParticipantSort" Value="ParticipantSort.JoinedAt">По времени записи</MudSelectItem>
        </MudSelect>
    </div>

    @if (Visible.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">Участники не найдены.</MudAlert>
    }
    else
    {
        <MudList T="QueueParticipantDto" Class="mt-2">
            @foreach (var p in Visible)
            {
                <MudListItem T="QueueParticipantDto" OnClick="@(() => OpenStudentAsync(p))" Style="@QueueStyles.RowStyle(p.Status)">
                    <div class="d-flex justify-space-between align-center flex-grow-1">
                        <div class="d-flex align-center gap-2">
                            <span style="@QueueStyles.NameStyle(p.StudentColor)"><b>@p.LastName @p.FirstName</b></span>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@p.GroupName</MudChip>
                        </div>
                        <div class="d-flex align-center gap-2">
                            <MudText>Баллы: <b>@p.TotalPoints</b></MudText>
                            <MudChip T="string" Color="@StatusColor(p.Status)" Size="Size.Small" Variant="Variant.Text">
                                @QueueStyles.StatusText(p.Status, p.CheckingByAdminName)
                            </MudChip>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    }
}
else
{
    <MudAlert Severity="Severity.Error">Не удалось загрузить данные очереди.</MudAlert>
}
