@page "/admin/grading"
@layout AdminLayout
@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>Студенты и оценки</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Студенты и оценки</MudText>

<MudSelect T="int?" @bind-Value="_subjectId" Label="Предмет" Variant="Variant.Outlined"
           Placeholder="Выберите предмет" Class="mb-3" Style="max-width: 360px;">
    @foreach (var s in _subjects) { <MudSelectItem T="int?" Value="@s.Id">@s.Name</MudSelectItem> }
</MudSelect>

<MudTextField @bind-Value="_query" Label="Поиск студента по фамилии" Variant="Variant.Outlined"
              Immediate="true" DebounceInterval="300" OnDebounceIntervalElapsed="SearchAsync"
              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" />

@if (_subjectId is null)
{
    <MudAlert Severity="Severity.Info" Class="mt-3">Выберите предмет, чтобы увидеть студентов и выставлять оценки.</MudAlert>
}
else if (_searching)
{
    <MudProgressLinear Indeterminate="true" Class="mt-3" />
}
else if (_results.Count > 0)
{
    <MudList T="StudentDetailsDto" Class="mt-2">
        @foreach (var student in _results)
        {
            <MudListItem T="StudentDetailsDto" OnClick="@(() => OpenAsync(student))">
                <div class="d-flex justify-space-between align-center flex-grow-1">
                    <span style="@QueueStyles.NameStyle(student.Color)">@student.LastName @student.FirstName</span>
                    <MudText Typo="Typo.caption">@student.Email</MudText>
                </div>
            </MudListItem>
            <MudDivider />
        }
    </MudList>
}
else
{
    <MudText Class="mt-3">Студенты не найдены.</MudText>
}
