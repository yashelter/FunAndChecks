@page "/admin/management"
@layout AdminLayout
@attribute [Authorize(Roles = Roles.Admin)]

<PageTitle>Создание</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Создание и связи</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudTabs Elevation="3" Rounded="true" Centered="true">
        <MudTabPanel Text="Предметы и группы">
            <MudGrid Class="mt-4">
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Создать предмет</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_subjectName" Label="Название предмета" Variant="Variant.Outlined" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateSubjectAsync">Создать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Создать группу</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudTextField @bind-Value="_groupName" Label="Название группы" Variant="Variant.Outlined"
                                          HelperText="Например: М8О-116БВ-21" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateGroupAsync">Создать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Задачи и очереди">
            <MudGrid Class="mt-4">
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Создать задачу</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudSelect T="int" @bind-Value="_taskSubjectId" Label="Предмет" Variant="Variant.Outlined">
                                @foreach (var s in _subjects) { <MudSelectItem T="int" Value="@s.Id">@s.Name</MudSelectItem> }
                            </MudSelect>
                            <MudTextField @bind-Value="_taskName" Label="Название задачи" Variant="Variant.Outlined" Class="mt-2" />
                            <MudTextField @bind-Value="_taskDescription" Label="Описание" Variant="Variant.Outlined" Lines="3" Class="mt-2" />
                            <MudNumericField @bind-Value="_taskMaxPoints" Label="Максимум баллов" Variant="Variant.Outlined" Class="mt-2" Min="1" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateTaskAsync">Создать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Создать событие (очередь)</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudSelect T="int" @bind-Value="_queueSubjectId" Label="Предмет" Variant="Variant.Outlined">
                                @foreach (var s in _subjects) { <MudSelectItem T="int" Value="@s.Id">@s.Name</MudSelectItem> }
                            </MudSelect>
                            <MudTextField @bind-Value="_queueName" Label="Название события" Variant="Variant.Outlined" Class="mt-2" />
                            <MudDatePicker @bind-Date="_queueDate" Label="Дата" Variant="Variant.Outlined" Class="mt-2" />
                            <MudTimePicker @bind-Time="_queueTime" Label="Время" Variant="Variant.Outlined" Class="mt-2" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateQueueAsync">Создать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Оценочные колонки">
            <MudGrid Class="mt-4" Justify="Justify.Center">
                <MudItem xs="12" md="8">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Добавить колонку оценки (билет, курсовая…)</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudSelect T="int" @bind-Value="_componentSubjectId" Label="Предмет" Variant="Variant.Outlined">
                                @foreach (var s in _subjects) { <MudSelectItem T="int" Value="@s.Id">@s.Name</MudSelectItem> }
                            </MudSelect>
                            <MudTextField @bind-Value="_componentName" Label="Название колонки" Variant="Variant.Outlined" Class="mt-2" />
                            <MudNumericField @bind-Value="_componentMaxPoints" Label="Максимум баллов" Variant="Variant.Outlined" Class="mt-2" Min="1" />
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateComponentAsync">Создать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Связи">
            <MudGrid Class="mt-4" Justify="Justify.Center">
                <MudItem xs="12" md="8">
                    <MudCard>
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Дать группе доступ к предмету</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudSelect T="int" @bind-Value="_linkSubjectId" Label="Предмет" Variant="Variant.Outlined">
                                @foreach (var s in _subjects) { <MudSelectItem T="int" Value="@s.Id">@s.Name</MudSelectItem> }
                            </MudSelect>
                            <MudSelect T="int" @bind-Value="_linkGroupId" Label="Группа" Variant="Variant.Outlined" Class="mt-2">
                                @foreach (var g in _groups) { <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem> }
                            </MudSelect>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LinkAsync">Связать</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
}
