<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>14</LangVersion>
        <!-- Хост раздаёт WASM через UseBlazorFrameworkFiles()+UseStaticFiles() (без MapStaticAssets,
             у него ETag-баг в dev). Без фингерпринтинга _framework имеет стабильные имена и
             грузится без import map. -->
        <WasmFingerprintAssets>false</WasmFingerprintAssets>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.9" />
        <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.9" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Frontend.Shared\Frontend.Shared.csproj" />
        <ProjectReference Include="..\Frontend.Admin\Frontend.Admin.csproj" />
        <ProjectReference Include="..\Frontend.Student\Frontend.Student.csproj" />
    </ItemGroup>

</Project>
