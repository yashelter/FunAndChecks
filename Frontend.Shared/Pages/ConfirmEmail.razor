@page "/confirm-email"
@layout AuthLayout

<PageTitle>Подтверждение почты</PageTitle>

<MudPaper Class="pa-8 mx-auto mt-16" MaxWidth="420px" Elevation="4">
    <MudText Typo="Typo.h5" Class="mb-2" Align="Align.Center">Подтверждение почты</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Align="Align.Center">
        Мы отправили код на вашу почту. Введите его, чтобы активировать аккаунт.
    </MudText>

    <MudForm @ref="_form">
        <MudTextField @bind-Value="_email" Label="Email" InputType="InputType.Email"
                      Required="true" RequiredError="Укажите email" Class="mb-3" />
        <MudTextField @bind-Value="_code" Label="Код из письма"
                      Required="true" RequiredError="Введите код" />
    </MudForm>

    @if (_error is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
    }
    @if (_info is not null)
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">@_info</MudAlert>
    }

    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6"
               OnClick="SubmitAsync" Disabled="_busy">
        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
        Подтвердить
    </MudButton>

    <div class="d-flex justify-space-between mt-4">
        <MudLink Href="/login">Ко входу</MudLink>
        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ResendAsync" Disabled="_busy">
            Отправить код повторно
        </MudButton>
    </div>
</MudPaper>
